                      "content":  "import React, { useState } from \u0027react\u0027;\n\ntype Page = \u0027home\u0027 | \u0027about\u0027 | \u0027contact\u0027;\n\nconst App: React.FC = () =\u003e {\n  const [currentPage, setCurrentPage] = useState\u003cPage\u003e(\u0027home\u0027);\n\n  const renderPage = () =\u003e {\n    switch (currentPage) {\n      case \u0027home\u0027:\n        return (\n          \u003csection id=\"home\" className=\"min-h-[calc(100vh-128px)] flex items-center justify-center bg-gradient-to-br from-primary to-secondary text-white py-16 px-4\"\u003e\n            \u003cdiv className=\"container mx-auto flex flex-col md:flex-row items-center gap-8\"\u003e\n              \u003cdiv className=\"md:w-1/2 text-center md:text-left\"\u003e\n                \u003ch1 className=\"text-5xl md:text-6xl font-bold mb-4 leading-tight\"\u003eHi, I\u0027m [Your Name]\u003c/h1\u003e\n                \u003cp className=\"text-xl md:text-2xl mb-6\"\u003eA passionate developer building modern web experiences.\u003c/p\u003e\n                \u003cbutton \n                  onClick={() =\u003e setCurrentPage(\u0027contact\u0027)}\n                  className=\"bg-accent hover:bg-opacity-90 text-white font-semibold py-3 px-8 rounded-full shadow-lg transition duration-300 ease-in-out transform hover:scale-105\"\n                \u003e\n                  Get in Touch\n                \u003c/button\u003e\n              \u003c/div\u003e\n              \u003cdiv className=\"md:w-1/2 flex justify-center\"\u003e\n                \u003cimg \n                  src=\"https://placehold.co/400x400/8E2DE2/FFFFFF/png?text=Developer\"\n                  alt=\"Developer working\"\n                  className=\"rounded-full shadow-2xl w-64 h-64 md:w-80 md:h-80 object-cover border-4 border-accent\"\n                /\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/section\u003e\n        );\n      case \u0027about\u0027:\n        return (\n          \u003csection id=\"about\" className=\"min-h-[calc(100vh-128px)] bg-background text-text_color py-16 px-4\"\u003e\n            \u003cdiv className=\"container mx-auto\"\u003e\n              \u003ch2 className=\"text-4xl font-bold text-center mb-10 text-primary\"\u003eAbout Me\u003c/h2\u003e\n              \u003cdiv className=\"flex flex-col md:flex-row items-center md:items-start gap-10\"\u003e\n                \u003cdiv className=\"md:w-1/3 flex justify-center\"\u003e\n                  \u003cimg \n                    src=\"https://placehold.co/300x300/4A00E0/FFFFFF/png?text=Profile\"\n                    alt=\"Profile Picture\"\n                    className=\"rounded-lg shadow-xl w-60 h-60 object-cover border-4 border-primary\"\n                  /\u003e\n                \u003c/div\u003e\n                \u003cdiv className=\"md:w-2/3 text-center md:text-left\"\u003e\n                  \u003cp className=\"text-lg leading-relaxed mb-6\"\u003e\n                    Hello! I\u0027m [Your Name], a frontend developer with a passion for creating beautiful and functional user interfaces. \n                    With expertise in React, TypeScript, and modern CSS frameworks like Tailwind CSS, I strive to build engaging and responsive web applications.\n                    My journey into development began with a fascination for how digital products come to life, and I\u0027ve been hooked ever since.\n                  \u003c/p\u003e\n                  \u003ch3 className=\"text-2xl font-semibold mb-4 text-secondary\"\u003eSkills\u003c/h3\u003e\n                  \u003cul className=\"grid grid-cols-2 sm:grid-cols-3 gap-4 text-left md:text-center mx-auto max-w-md\"\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eReact\u003c/li\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eTypeScript\u003c/li\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eTailwind CSS\u003c/li\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eJavaScript\u003c/li\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eHTML \u0026 CSS\u003c/li\u003e\n                    \u003cli className=\"bg-white p-3 rounded-lg shadow-md text-center hover:bg-primary hover:text-white transition duration-300\"\u003eGit\u003c/li\u003e\n                  \u003c/ul\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/section\u003e\n        );\n      case \u0027contact\u0027:\n        return (\n          \u003csection id=\"contact\" className=\"min-h-[calc(100vh-128px)] bg-gradient-to-br from-secondary to-primary text-white py-16 px-4\"\u003e\n            \u003cdiv className=\"container mx-auto\"\u003e\n              \u003ch2 className=\"text-4xl font-bold text-center mb-10\"\u003eContact Me\u003c/h2\u003e\n              \u003cdiv className=\"flex flex-col md:flex-row items-center gap-10\"\u003e\n                \u003cdiv className=\"md:w-1/2 flex justify-center\"\u003e\n                  \u003cimg \n                    src=\"https://placehold.co/400x300/FF00C1/FFFFFF/png?text=Contact\"\n                    alt=\"Contact illustration\"\n                    className=\"rounded-lg shadow-2xl w-full max-w-md object-cover border-4 border-accent\"\n                  /\u003e\n                \u003c/div\u003e\n                \u003cdiv className=\"md:w-1/2 bg-white p-8 rounded-lg shadow-2xl text-text_color\"\u003e\n                  \u003cform className=\"space-y-6\"\u003e\n                    \u003cdiv\u003e\n                      \u003clabel htmlFor=\"name\" className=\"block text-lg font-medium text-gray-700\"\u003eName\u003c/label\u003e\n                      \u003cinput \n                        type=\"text\" \n                        id=\"name\" \n                        name=\"name\" \n                        className=\"mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-base\"\n                        placeholder=\"Your Name\"\n                      /\u003e\n                    \u003c/div\u003e\n                    \u003cdiv\u003e\n                      \u003clabel htmlFor=\"email\" className=\"block text-lg font-medium text-gray-700\"\u003eEmail\u003c/label\u003e\n                      \u003cinput \n                        type=\"email\" \n                        id=\"email\" \n                        name=\"email\" \n                        className=\"mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-base\"\n                        placeholder=\"you@example.com\"\n                      /\u003e\n                    \u003c/div\u003e\n                    \u003cdiv\u003e\n                      \u003clabel htmlFor=\"message\" className=\"block text-lg font-medium text-gray-700\"\u003eMessage\u003c/label\u003e\n                      \u003ctextarea \n                        id=\"message\" \n                        name=\"message\" \n                        rows={4} \n                        className=\"mt-1 block w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-primary focus:border-primary sm:text-base\"\n                        placeholder=\"Your message...\"\n                      \u003e\u003c/textarea\u003e\n                    \u003c/div\u003e\n                    \u003cbutton \n                      type=\"submit\"\n                      className=\"w-full bg-accent hover:bg-opacity-90 text-white font-semibold py-3 px-4 rounded-md shadow-lg transition duration-300 ease-in-out transform hover:scale-105\"\n                    \u003e\n                      Send Message\n                    \u003c/button\u003e\n                  \u003c/form\u003e\n                  \u003cdiv className=\"mt-8 text-center\"\u003e\n                    \u003cp className=\"text-lg mb-4 text-gray-700\"\u003eFind me on social media:\u003c/p\u003e\n                    \u003cdiv className=\"flex justify-center space-x-6\"\u003e\n                      \u003ca href=\"#\" className=\"text-primary hover:text-accent transition duration-300 text-3xl\"\u003e\u003ci className=\"fab fa-github\"\u003e\u003c/i\u003eGH\u003c/a\u003e\n                      \u003ca href=\"#\" className=\"text-primary hover:text-accent transition duration-300 text-3xl\"\u003e\u003ci className=\"fab fa-linkedin\"\u003e\u003c/i\u003eLI\u003c/a\u003e\n                      \u003ca href=\"#\" className=\"text-primary hover:text-accent transition duration-300 text-3xl\"\u003e\u003ci className=\"fab fa-twitter\"\u003e\u003c/i\u003eTW\u003c/a\u003e\n                    \u003c/div\u003e\n                  \u003c/div\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/section\u003e\n        );\n      default:\n        return null;\n    }\n  };\n\n  return (\n    \u003cdiv className=\"font-sans antialiased bg-background min-h-screen flex flex-col\"\u003e\n      \u003cnav className=\"bg-primary text-white p-4 shadow-md\"\u003e\n        \u003cdiv className=\"container mx-auto flex justify-between items-center\"\u003e\n          \u003ca href=\"#\" onClick={() =\u003e setCurrentPage(\u0027home\u0027)} className=\"text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-accent to-white hover:opacity-80 transition duration-300\"\u003e\n            [Your Name] Portfolio\n          \u003c/a\u003e\n          \u003cul className=\"flex space-x-6\"\u003e\n            \u003cli\u003e\n              \u003cbutton \n                onClick={() =\u003e setCurrentPage(\u0027home\u0027)} \n                className={`text-lg hover:text-accent transition duration-300 ${currentPage === \u0027home\u0027 ? \u0027text-accent\u0027 : \u0027\u0027}`}\n              \u003e\n                Home\n              \u003c/button\u003e\n            \u003c/li\u003e\n            \u003cli\u003e\n              \u003cbutton \n                onClick={() =\u003e setCurrentPage(\u0027about\u0027)} \n                className={`text-lg hover:text-accent transition duration-300 ${currentPage === \u0027about\u0027 ? \u0027text-accent\u0027 : \u0027\u0027}`}\n              \u003e\n                About\n              \u003c/button\u003e\n            \u003c/li\u003e\n            \u003cli\u003e\n              \u003cbutton \n                onClick={() =\u003e setCurrentPage(\u0027contact\u0027)} \n                className={`text-lg hover:text-accent transition duration-300 ${currentPage === \u0027contact\u0027 ? \u0027text-accent\u0027 : \u0027\u0027}`}\n              \u003e\n                Contact\n              \u003c/button\u003e\n            \u003c/li\u003e\n          \u003c/ul\u003e\n        \u003c/div\u003e\n      \u003c/nav\u003e\n\n      \u003cmain className=\"flex-grow\"\u003e\n        {renderPage()}\n      \u003c/main\u003e\n\n      \u003cfooter className=\"bg-secondary text-white p-4 text-center shadow-inner mt-auto\"\u003e\n        \u003cdiv className=\"container mx-auto\"\u003e\n          \u003cp\u003e\u0026copy; {new Date().getFullYear()} [Your Name]. All rights reserved.\u003c/p\u003e\n        \u003c/div\u003e\n      \u003c/footer\u003e\n    \u003c/div\u003e\n  );\n};\n\nexport default App;",
