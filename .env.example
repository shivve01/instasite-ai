# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Server
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PORT=3001
NODE_ENV=development

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI Provider (choose one)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GEMINI_API_KEY= 
# ANTHROPIC_API_KEY=sk-ant-...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI Model Config
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_MAX_TOKENS=16000
AI_TEMPERATURE=0.7

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Rate Limiting
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Frontend
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
VITE_API_URL=http://localhost:3001/api
